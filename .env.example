# Primary automated discovery source.
# Obtain this from Apollo, then export it in your shell or copy this file to .env.
APOLLO_API_KEY=

DATABASE_PATH=data/lead_discovery.sqlite

# Future email digest config; leave unset unless explicitly enabling send.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER=
DIGEST_RECIPIENT=

# Reader LLM uses the local Codex CLI login by default.
# Used by: lead-discovery fetch-website --reader-output data/example-reader.json
# No Gemini API key is required.

# Future LLM provider adapters; not required for MVP.
LLM_PROVIDER=
LLM_API_KEY=
